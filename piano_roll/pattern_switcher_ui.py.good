#!/usr/bin/env python3
"""
Modern GUI for switching FL Studio patterns using PyQt5.

Shows buttons for patterns 1, 2, 3 that trigger pattern switching
via FL Studio dual-controller API calls using SysEx MIDI.
"""

import sys
from pathlib import Path

# Add parent directory to path for imports
sys.path.insert(0, str(Path(__file__).parent.parent))

import json
from PyQt5.QtWidgets import (QApplication, QMainWindow, QWidget, QVBoxLayout,
                             QPushButton, QLabel, QFrame, QTextEdit, QDialog, QVBoxLayout as QVBoxDialogLayout)
from PyQt5.QtCore import Qt
from PyQt5.QtGui import QFont, QPalette, QColor
from midi_controller.fl_dual_port import send_command, close_ports
from piano_roll_utils import trigger_with_f3_plus_9, print_piano_roll_info
from midi_controller.focus_management import activate_fl_studio
from pathlib import Path

class PatternSwitcherUI(QMainWindow):
    def __init__(self):
        super().__init__()
        self.switching = False  # Flag to prevent simultaneous switches
        self.patterns = self.load_patterns()
        self.setup_ui()

    def load_patterns(self):
        """Load pattern names dynamically from FL Studio."""
        patterns = {}
        try:
            # Get the actual pattern count
            pattern_count = int(send_command("patterns.patternCount()"))
            print(f"Loading {pattern_count} patterns...")

            # Query each pattern (1-based indexing)
            for i in range(1, pattern_count + 1):
                name = send_command(f"patterns.getPatternName({i})")
                if name and name.strip():
                    patterns[i] = name.strip()
                    print(f"  Pattern {i}: {name}")

            print(f"Loaded {len(patterns)} patterns")

            # Fallback if no patterns found
            if not patterns:
                print("No patterns found, using defaults")
                patterns = {1: "Pattern 1", 2: "Pattern 2", 3: "Pattern 3"}

        except Exception as e:
            print(f"Error loading patterns: {e}")
            # Fallback to default patterns
            patterns = {1: "Pattern 1", 2: "Pattern 2", 3: "Pattern 3"}

        return patterns

    def setup_ui(self):
        """Create the modern PyQt5 interface."""
        self.setWindowTitle("FL Studio Pattern Switcher")
        self.resize(600, 600)
        self.setMinimumSize(200, 300)

        # Make window always on top
        self.setWindowFlags(self.windowFlags() | Qt.WindowStaysOnTopHint)

        # Dark theme
        self.setStyleSheet("""
            QMainWindow {
                background-color: #1e1e1e;
            }
        """)

        # Central widget and layout
        central_widget = QWidget()
        self.setCentralWidget(central_widget)
        layout = QVBoxLayout(central_widget)
        layout.setContentsMargins(25, 25, 25, 25)
        layout.setSpacing(15)

        # Title
        title = QLabel("FL Studio Pattern Switcher")
        title.setFont(QFont("Helvetica Neue", 18, QFont.Bold))
        title.setStyleSheet("color: #6495ED; padding: 5px;")
        title.setAlignment(Qt.AlignCenter)
        layout.addWidget(title)

        # Status label (shows current pattern)
        self.status_label = QLabel("No pattern selected")
        self.status_label.setFont(QFont("Helvetica Neue", 13, QFont.Bold))
        self.status_label.setStyleSheet("color: #00ff88; padding: 10px;")
        self.status_label.setAlignment(Qt.AlignCenter)
        layout.addWidget(self.status_label)

        layout.addSpacing(10)

        # Pattern buttons
        for pattern_num, pattern_name in self.patterns.items():
            btn = QPushButton(f"{pattern_num}. {pattern_name}")
            btn.setMinimumHeight(50)
            btn.setFont(QFont("Helvetica Neue", 14, QFont.Bold))
            btn.setCursor(Qt.PointingHandCursor)
            btn.setStyleSheet("""
                QPushButton {
                    background-color: #4a4a4a;
                    color: white;
                    border: none;
                    border-radius: 6px;
                    padding: 10px;
                }
                QPushButton:hover {
                    background-color: #5a5a5a;
                }
                QPushButton:pressed {
                    background-color: #3a3a3a;
                }
                QPushButton:disabled {
                    background-color: #2a2a2a;
                    color: #666;
                }
            """)
            btn.clicked.connect(lambda checked, num=pattern_num, name=pattern_name:
                              self.switch_pattern(num, name))
            layout.addWidget(btn)

        layout.addSpacing(10)

        # Update LLM button
        update_llm_btn = QPushButton("Update LLM")
        update_llm_btn.setMinimumHeight(40)
        update_llm_btn.setFont(QFont("Helvetica Neue", 12, QFont.Bold))
        update_llm_btn.setCursor(Qt.PointingHandCursor)
        update_llm_btn.setStyleSheet("""
            QPushButton {
                background-color: #2a8a5a;
                color: white;
                border: none;
                border-radius: 6px;
                padding: 8px;
            }
            QPushButton:hover {
                background-color: #3a9a6a;
            }
            QPushButton:pressed {
                background-color: #1a7a4a;
            }
        """)
        update_llm_btn.clicked.connect(self.update_llm)
        layout.addWidget(update_llm_btn)

        layout.addSpacing(10)

        # Notes display area
        notes_label = QLabel("Piano Roll Notes:")
        notes_label.setFont(QFont("Helvetica Neue", 11))
        notes_label.setStyleSheet("color: #999;")
        layout.addWidget(notes_label)

        self.notes_text = QTextEdit()
        self.notes_text.setReadOnly(True)
        self.notes_text.setFont(QFont("Monaco", 9))
        self.notes_text.setMinimumHeight(300)  # Taller for ~20 notes
        self.notes_text.setStyleSheet("""
            QTextEdit {
                background-color: #1a1a1a;
                color: #ccc;
                border: 1px solid #444;
                border-radius: 4px;
                padding: 5px;
            }
        """)
        layout.addWidget(self.notes_text)

        # Load notes on startup
        self.refresh_notes()

    def switch_pattern(self, pattern_num, pattern_name):
        """Switch to the specified pattern and trigger piano roll script."""
        print(f"\n=== Switching to pattern {pattern_num}: {pattern_name} ===", flush=True)

        # Prevent simultaneous switches
        if self.switching:
            print("⚠️  Already switching, ignoring...", flush=True)
            return

        self.switching = True

        try:
            # Update UI to show we're working
            self.status_label.setText(f"Switching to {pattern_name}...")
            self.status_label.setStyleSheet("color: #ffaa00; padding: 10px;")
            QApplication.processEvents()  # Update UI immediately

            # Activate FL Studio
            activate_fl_studio()

            # Switch pattern using dual-controller system
            send_command(f"patterns.jumpToPattern({pattern_num})")

            # Show and focus piano roll
            send_command("ui.showWindow(3)")
            send_command("ui.setFocused(3)")

            # Trigger piano roll script via keyboard shortcut
            self.status_label.setText(f"Running script...")
            QApplication.processEvents()  # Update UI
            trigger_with_f3_plus_9()

            # Success
            self.status_label.setText(f"{pattern_num}. {pattern_name}")
            self.status_label.setStyleSheet("color: #00ff88; padding: 10px;")
            print_piano_roll_info()

            # Refresh notes display
            self.refresh_notes()

        except Exception as e:
            print(f"✗ Exception: {e}", flush=True)
            import traceback
            traceback.print_exc()
            self.status_label.setText(f"Error: {str(e)}")
            self.status_label.setStyleSheet("color: #ff4444; padding: 10px;")
        finally:
            # Always reset the switching flag
            self.switching = False
            close_ports()

    def update_llm(self):
        """Update LLM by triggering piano roll script without switching patterns."""
        print("\n=== Updating LLM ===", flush=True)

        try:
            self.status_label.setText("Updating LLM...")
            self.status_label.setStyleSheet("color: #ffaa00; padding: 10px;")
            QApplication.processEvents()

            # Activate FL Studio
            activate_fl_studio()

            # Show and focus piano roll
            send_command("ui.showWindow(3)")
            send_command("ui.setFocused(3)")

            # Trigger the piano roll script to update state
            trigger_with_f3_plus_9()

            # Add delay to ensure file is written by FL Studio
            import time
            time.sleep(0.3)
            QApplication.processEvents()  # Process any pending events

            # Refresh notes display
            self.refresh_notes()

            # Print piano roll info
            print_piano_roll_info()

            self.status_label.setText("LLM updated")
            self.status_label.setStyleSheet("color: #00ff88; padding: 10px;")

        except Exception as e:
            print(f"✗ Exception: {e}", flush=True)
            import traceback
            traceback.print_exc()
            self.status_label.setText(f"Error: {e}")
            self.status_label.setStyleSheet("color: #ff4444; padding: 10px;")

    def refresh_notes(self):
        """Refresh and display current piano roll notes."""
        try:
            # Read piano roll state
            state_file = Path.home() / "Documents/Image-Line/FL Studio/Settings/Piano roll scripts/piano_roll_state.json"

            if not state_file.exists():
                self.notes_text.setPlainText("No piano roll state found.\nRun ComposeWithLLM script or click 'Update LLM'.")
                return

            with open(state_file, 'r') as f:
                state = json.load(f)

            note_names = ['C', 'C#', 'D', 'D#', 'E', 'F', 'F#', 'G', 'G#', 'A', 'A#', 'B']

            notes = state.get('notes', [])

            if not notes:
                notes_str = "Total Notes: 0\n\n(No notes in piano roll)"
            else:
                # Sort by MIDI number
                sorted_notes = sorted(notes, key=lambda n: n['number'])

                # Format as note names
                note_list = []
                for note in sorted_notes:
                    midi_num = note['number']
                    note_name = note_names[midi_num % 12]
                    octave = (midi_num // 12) - 1
                    note_list.append(f"{note_name}{octave}")

                notes_str = f"Total Notes: {len(notes)}\n\n"
                notes_str += ", ".join(note_list)

            self.notes_text.setPlainText(notes_str)

        except Exception as e:
            self.notes_text.setPlainText(f"Error loading notes: {e}")
            print(f"Error viewing notes: {e}")

def main():
    """Main entry point."""
    app = QApplication(sys.argv)

    # Set application-wide dark palette
    palette = QPalette()
    palette.setColor(QPalette.Window, QColor(30, 30, 30))
    palette.setColor(QPalette.WindowText, Qt.white)
    app.setPalette(palette)

    window = PatternSwitcherUI()
    window.show()
    sys.exit(app.exec_())

if __name__ == '__main__':
    try:
        main()
    except KeyboardInterrupt:
        print("\n🛑 UI closed by user")
    finally:
        try:
            close_ports()
            print("🔌 MIDI ports closed")
        except:
            pass
        print("👋 Goodbye!")
