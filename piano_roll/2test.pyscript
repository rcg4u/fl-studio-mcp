import flpianoroll as flp
from flpianoroll import score

def createDialog():
    # This function creates the user interface for the script
    form = flp.ScriptDialog("Shift Up 1 Semitone", "")
    # Add a simple label to the dialog
    form.AddInputText("Info", "This script shifts all selected notes up by 1 semitone.")
    return form

def apply(form):
    # This function contains the main logic that runs when the user clicks 'Apply'

    # Get all notes currently in the piano roll (or only selected ones if any are selected)
    # The API documentation implies that scripts operate on selected notes first, then all
    # if nothing is selected.
    notes = [score.getNote(i) for i in range(score.noteCount)]
    
    if not notes:
        # Optional: Print a message to the script output window if no notes are found
        print("No notes found in the Piano roll.")
        return

    # Iterate through each note and modify its pitch
    for note in notes:
        # Increment the note number (MIDI pitch value) by 1
        note.number += 1
        # Re-select the note after modification, as some scripts might deselect them
        note.selected = True

    # Note: Changes to note attributes are applied automatically.
    # No explicit 'save' or 'update' function is typically needed within the loop.

